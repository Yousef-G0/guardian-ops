FROM golang:1.21-alpine AS builder

WORKDIR /build

# Install dependencies
RUN apk add --no-cache git

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY cmd/api ./cmd/api

# Build
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o security-api ./cmd/api

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates curl jq

WORKDIR /app

COPY --from=builder /build/security-api .

EXPOSE 8080

CMD ["./security-api"]
