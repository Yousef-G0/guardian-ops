FROM golang:1.21-alpine AS builder

WORKDIR /build

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/agent ./cmd/agent

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o runtime-agent ./cmd/agent

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates curl net-tools procps

WORKDIR /app

COPY --from=builder /build/runtime-agent .

# Create log directory
RUN mkdir -p /var/log/guardian-ops

CMD ["./runtime-agent"]
